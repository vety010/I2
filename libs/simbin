-- SIMBIN always uses LITTLE ENDIAN notation for binary and hex operations.

-- Returns true if the given integer is a 1
local function b(str)
     return str == "1"
end



converters = {}
converters.binToBool = b

bops = {}
binaryOperations = bops

-- int         - the number to be converted
-- maxBits     - maximum number of bits to be written
--               Note: In Little Endian this cuts off the most significant bits (digits)
--               It is much better to limit the number elsehow if this behaviour is not something you expect to happen
-- fullBits    - do not stop if the number is 0 and always write maxBits
--
-- Does not support negatives.
function converters.uintToBin(int, maxBits, fullBits)
     int = tonumber(int)

     local s = ""

     for i = 1, (maxBits or 128) do
          s = s .. tostring(int % 2)
          int = math.floor(int / 2)

          if not fullBits and int <= 0 then break end
     end

     return s
end



-- bin         - the binary string to be converted
--
-- Does not support negatives.
function converters.binToUInt(bin)
     local int = 0
     local po2 = 1
     
     for i = 1, #bin do
          int = int + tonumber(bin:sub(i, i)) * po2
          po2 = po2 * 2
     end

     return int
end



-- Binary inclusive OR
function bops.b_or(binA, binB)
     local result = ""
     
     for i = 1, math.max(#binA, #binB) do
          result = result .. ((b(binA:sub(i, i)) or b(binB:sub(i, i))) and "1" or "0")
     end

     return result
end



-- Binary exclusive OR (XOR)
function bops.b_xor(binA, binB)
     local result = ""
     
     for i = 1, math.max(#binA, #binB) do
          result = result .. ((b(binA:sub(i, i)) ~= b(binB:sub(i, i))) and "1" or "0")
     end

     return result
end



-- Binary AND 
function bops.b_and(binA, binB)
     local result = ""
     
     for i = 1, math.max(#binA, #binB) do
          result = result .. ((b(binA:sub(i, i)) and b(binB:sub(i, i))) and "1" or "0")
     end

     return result
end



-- Binary invert (NOT)
function bops.b_invert(binA)
     local result = ""
     
     for i = 1, math.max(#binA) do
          result = result .. (not b(binA:sub(i, i)) and "1" or "0")
     end

     return result
end



