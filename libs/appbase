function printStats()
    local cx, cy = term.getCursorPos()

    local linesCount = 4

    -- Clearing lines needed for correct display
    for i = 2, 4 do
        term.setCursorPos(1, i)
        term.clearLine()
    end

    -- Set cursor to start
    term.setCursorPos(1, 2)

    local isBreach = getCMDVar("breach active")
    local isLockdown = getCMDVar("lockdown active")
    local powerState = getCMDVar("power state")

    print("Breach mode: "..(isBreach and "YES" or "NO"))
    print("Lockdown mode: "..((isBreach or isLockdown) and "YES" or "NO"))
    print("Power: "..string.upper(powerState))
    if isBreach and not isLockdown then
        print("LOCKDOWN WAS ISSUED BECAUSE OF THE BREACH")
    end
    
    -- Return cursor afterwards
    term.setCursorPos(cx, cy)
end

function rerenderStats()
    if memory.terminal.awaitingConfirm then return end

    printStats()
end

reset()
printStats()

function onKey(key, is_held)
    local k = keys.getName(key)

    local cursorX, cursorY = term.getCursorPos()

    if k and #k == 1 and not is_held then
        memory.terminal.str = memory.terminal.str .. k
        term.write(k)
    elseif numbers[k] and not is_held then
        memory.terminal.str = memory.terminal.str .. numbers[k]
        term.write(numbers[k])
    elseif k == "enter" then
        if memory.terminal.awaitingConfirm then
            -- Resetting state
            memory.terminal.awaitingConfirm = false

            -- Clearing
            memory.terminal.str = ""
            reset()
            printStats()
        else
            reset()
            -- Set cursor to start
            term.setCursorPos(1, 2)
            -- Parse the command
            parseCommand(memory.terminal.str)
            -- Set bottom text to "awaiting confirm"
            term.setCursorPos(1, h)
            term.clearLine()
            term.write("COMMAND EXECUTED. ENTER TO RETURN")
            -- And await the confirmation
            memory.terminal.awaitingConfirm = true
        end
    elseif k == "backspace" and cursorX > 3 then
        -- Remove one symbol from the input
        memory.terminal.str = string.sub(memory.terminal.str, 1, -2)
        -- Set cursor pos back one symbol
        term.setCursorPos(cursorX - 1, h)
        -- Sets the symbol to empty (space)
        term.write(" ")
        -- Set cursor pos back one symbol again
        term.setCursorPos(cursorX - 1, h)
    elseif k == "space" then
        memory.terminal.str = memory.terminal.str .. " "
        term.write(" ")
    -- elseif k == "rightCtrl" then
    elseif key == 157 then -- Right control. For some reason does not have a nice name.
        -- Reset carriage before exit
        term.setCursorPos(1, h - 1)
        -- Print the exited text, clearing the lines beforehand
        term.clearLine()
        print("-- EXITED")
        term.clearLine()
        
        hook.run("stopProgramExecution")
    end
end

hook.add("onEvent_key", "cli", onKey)
hook.add("second", "cli", rerenderStats)

