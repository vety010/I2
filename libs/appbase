-- Callback arguments:
-- k - current key (any, usually string)
-- v - current value (any)
-- depth - current depth (number)
-- parent - "parent[k]" is the "v" value
-- path - entire path (table)
-- 
-- 1st argument: true if we need to go a level deeper, false otherwise.
-- 2nd argument: any result to be returned as the result of traversing
function traverseCMDTree(str, callback)
    local path = splitBySpaces(str)
    local depth = 0
    local current = commandTree

    while true do
        depth = depth + 1

        if depth > 20 then
            print("Invalid path length")
            return nil
        end

        if not path[depth] then
            print("Incomplete path!")
            return nil
        end

        local k = path[depth]
        local v = current[k]

        local deeper, result = callback(k, v, depth, current, path)
        
        if deeper then 
            current = v
        else
            return result 
        end
    end
end

function setCMDVar(path, value)
    traverseCMDTree(path, function(k, v, depth, current, path)
        if depth == #path then
            current[k] = value

            return false, value
        end

        return true
    end)
end

function getCMDVar(path)
    return traverseCMDTree(path, function(k, v, depth, current, path)
        if depth == #path then
            return false, current[k]
        end
        
        return true
    end)
end

function parseCommand(str)
    traverseCMDTree(str, function(k, v, depth, current, path)
        if type(v) == "table" then
            return true
        elseif type(v) == "function" then
            local args = {}

            for i = depth + 1, #path do
                table.insert(args, path[i])
            end

            return false, v(args, unpack(args))
        elseif type(v) == "boolean" then
            print("[VAR] Value of "..k.." is "..(v and "true" or "false").." (boolean)")
            
            return false, v
        elseif type(v) == "number" then
            print("[VAR] Value of "..k.." is "..v.." (number)")
            
            return false, v
        elseif type(v) == "string" then
            print("[VAR] Value of "..k.." is "..v.." (string)")
            
            return false, v
        else
            print("Not recognized as directory, command or variable (step '"..k.."').")
        end
        
        return false, nil
    end)
end

