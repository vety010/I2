os.loadAPI("/disk/libs/utils")
os.loadAPI("/disk/libs/hook")

os.loadAPI("/disk/net/base/i2_nics")

-- Frame syntax:
-- SRC, DST - Source/Destination MACs 
-- TYPE - Type of frame (C means the frame must be delivered to a client, rerouted or dropped - a switch cannot consume it): 
--        C R for request, 
--        C A for response, 
--        C E for error (for example, unable to find route), 
--          S for system, 
--          C for config,
--          B for broadcast, 
--          M for MAC discovery (LLDP)
-- TYPE SRC DST VLAN FRAME

config = {
     -- 0 for primitive
     -- 1 for simple
     -- 2 for advanced
     -- 3 for managed
     switch_type = 0
}

-- Making NIC manager accessible
i2_nics = i2_nics

print("[I2] SWITCH UP")

-- This object contains callbacks because otherwise we have no way of safely overriding them.
callbacks = {}

-- To be called whenever the device forwards a frame to another device
function callbacks.onForwardedFrame(fromNIC, toNIC, frameType, source, destination, vlan, frame)
     toNIC:send(fromNIC, frameType, source, destination, vlan, frame)
end

-- NIC:        NIC __FROM__ which we received the frame. Nil if originating from this device.
-- frameType: See above.
-- frame:     The frame body

-- Called when the switch needs to forward a frame
function onFrame(fromNIC, frameType, source, destination, vlan, frame)
     -- Get MAc address of the NIC
     local MAC = fromNIC:getMAC()

     -- Only enable MAC lookups for simple switches or above.
     if config.switch_type >= 1 then
          -- Iterate over all NICs, find one that has MAC of the recepient
          for side, nextNIC in pairs(i2_nics.getAll()) do
               if nextNIC:getOpponentsMAC() == destination then
                    return callbacks.onForwardedFrame(fromNIC, nextNIC, frameType, source, destination, vlan, frame)
               end
          end
     end
     
     -- Broadcast the frame (except to the origin port) if we have no idea where to put it lol. switches are weird :P
     for side, nextNIC in pairs(i2_nics.getAll()) do
          if nextNIC ~= fromNIC then
               callbacks.onForwardedFrame(fromNIC, nextNIC, frameType, source, destination, vlan, frame)
          end
     end
end

hook.add("i2.NICs.inbound_frame", "i2.switch.inbound", function(...) onFrame(...) end)