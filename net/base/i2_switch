os.loadAPI("/disk/libs/utils")
os.loadAPI("/disk/libs/hook")

os.loadAPI("/disk/net/base/i2_nics")

config = {
     -- 0 for primitive
     -- 1 for simple
     -- 2 for advanced
     -- 3 for managed (WIP)
     switch_type = 2
}

local switching_cache = {}

-- destinationMAC - MAC address which should flow via a port
-- viaMAC - MAC address of the NIC where this frame should flow
local function addMACCacheRecord(destinationMAC, viaMAC)
     switching_cache[destinationMAC] = viaMAC
end

local function getMACCache(destinationMAC)
     return switching_cache[destinationMAC]
end

local function removeMACCacheRecord(destinationMAC)
     switching_cache[destinationMAC] = nil
end 

function resetMACCache()
     switching_cache = {}
end

-- Making NIC manager accessible
i2_nics = i2_nics

print("[I2] SWITCH UP")

-- This object contains callbacks because otherwise we have no way of safely overriding them.
callbacks = {}

-- To be called whenever the device forwards a frame to another device
function callbacks.onForwardedFrame(fromNIC, toNIC, source, destination, vlan, frameType, frame)
     toNIC:send(fromNIC, source, destination, vlan, frameType, frame)
end

-- Called when the switch needs to forward a frame
function onFrame(fromNIC, source, destination, vlan, frameType, frame)
     -- Get MAc address of the NIC
     local MAC = fromNIC:getMAC()

     -- Enable MAC flow caching for 
     if config.switch_type >= 2 then
          -- Adding a cache record that a device with this MAC exists on this NIC
          addMACCacheRecord(source, MAC)
     end

     -- Only enable MAC lookups for simple switches or above.
     if config.switch_type >= 1 then
          -- Iterate over all NICs, find one that has MAC of the recepient
          for side, nextNIC in pairs(i2_nics.getAll()) do
               if nextNIC:getOpponentsMAC() == destination then
                    callbacks.onForwardedFrame(fromNIC, nextNIC, source, destination, vlan, frameType, frame)
                    return 
               end
          end
     end

     -- Enable MAC flow caching for 
     local nextNIC_macAddress = config.switch_type >= 2 and getMACCache(destination)
     if nextNIC_macAddress then
          -- Iterate over all NICs, find one that has MAC of the recepient cached
          for side, nextNIC in pairs(i2_nics.getAll()) do
               if nextNIC:getMAC() == nextNIC_macAddress then
                    callbacks.onForwardedFrame(fromNIC, nextNIC, source, destination, vlan, frameType, frame)
                    return 
               end
          end

          removeMACCacheRecord(destination)
     end
     
     -- Broadcast the frame (except to the origin port) if we have no idea where to put it lol. switches are weird :P
     for side, nextNIC in pairs(i2_nics.getAll()) do
          if nextNIC ~= fromNIC then
               callbacks.onForwardedFrame(fromNIC, nextNIC, source, destination, vlan, frameType, frame)
          end
     end
end

hook.add("i2.NICs.inbound_frame", "i2.switch.inbound", function(...) onFrame(...) end)