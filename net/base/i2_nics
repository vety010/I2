os.loadAPI("/disk/libs/simbin")
os.loadAPI("/disk/net/base/mac_address")

local metatable = {}
local existingNICs = {}

local I2_CHANNEL = 0

-- HOOKS:
--   i2.NICs.inbound_frame   -- called whenever a NIC has received inbound traffic
--   i2.NICs.registered       -- called whenever a NIC was registered
--   i2.NICs.unregistered     -- called whenever a NIC was unregistered

---------------------------------
--   NIC METATABLE FUNCTIONS   --
---------------------------------

-- If isVirtual is true, side actually acts as the ID of the virtual interface
function metatable:initialize(isVirtual, side, index)
     self.virtual = isVirtual
     self.index = index
     
     if not isVirtual then
          self.peripheral = peripheral.wrap(side)
          
          -- Init I2 channel
          self.peripheral.open(I2_CHANNEL)
     end
     
     self.side = side
     existingNICs[side] = self
end

-- Called whenever NIC has to be destroyed.
function metatable:destroy()
     existingNICs[self.side] = nil
end

function metatable:setOpponentsMAC(mac)
     self.link_mac = mac
end

function metatable:getOpponentsMAC()
     return self.link_mac
end

-- Returns the NIC's MAC address
function metatable:getMAC()
     if not self.mac then
          -- TODO: proper isClient flag
          self.mac = mac_address.get(self.index, self.side, self.virtual, not self.virtual)
     end

     return self.mac
end

-- nic RECEIVES from internal and *SENDS* to another computer
-- Sends a frame via this NIC, also has the origin NIC for routing purposes
-- To be overridden.
function metatable:send(originNIC, frameType, source, destination, vlan, frame)
     if self.virtual then return end
     
     self.peripheral.transmit(I2_CHANNEL, I2_CHANNEL, self:packFrame(frameType, source, destination, vlan, frame))
end

-- nic SENDS to internal as a result of *RECEIVING* from another computer
-- Whenever this NIC receives an external frame
function metatable:receive(frameType, src, dst, vlan, body)
     hook.run("i2.NICs.inbound_frame", self, frameType, src, dst, vlan, body)
end

-- Packs frame data into the formatted string
function metatable:packFrame(frameType, source, destination, vlan, frame)
     return tostring(frameType and frameType:sub(1,1) or "-") .. 
          tostring(mac_address.toHex(source or mac_address.zero)) .. 
          tostring(mac_address.toHex(destination or mac_address.zero)) .. 
          tostring(simbin.converters.uintToHex(vlan or 0, 3, true)) .. 
          tostring(frame or "")
end

-- Sends MAC discovery packet
function metatable:shareMAC()
     self:send(nil, "M", self:getMAC(), self:getOpponentsMAC(), nil, nil)
end

metatable.__index = metatable

---------------------------------------
--   GLOBAL NIC HANDLING FUNCTIONS   --
---------------------------------------

local NICIndexCounter = 0

function getAll()
     return existingNICs
end

function getAtSide(side)
     return getAll()[side]
end

function updateNICs()
     -- Checking NICs that are no longer active
     local toBeRemoved = {}
     for side, nic in pairs(existingNICs) do
          if not peripheral.isPresent(side) then
               table.insert(toBeRemoved, side)
          end  
     end

     -- Removing any inactive NICs
     for k, v in ipairs(toBeRemoved) do 
          unregisterNIC(v)
     end

     -- Adding any new NICs
     for k, v in pairs(peripheral.getNames()) do
          if peripheral.getType(v) == "modem" and not existingNICs[v] then
               registerNIC(v, false)
          end
     end

     return nil
end

function registerNIC(side, isVirtual)
     print("[I2] Registering NIC #"..NICIndexCounter..": "..side)

     if getAtSide(side) then 
          unregisterNIC(side)
     end

     -- Creating a NIC object
     local NIC = {}
     setmetatable(NIC, metatable)
     NIC:initialize(isVirtual, side, NICIndexCounter)

     print("[I2] NIC #"..NICIndexCounter..": "..NIC:getMAC())

     NICIndexCounter = NICIndexCounter + 1

     hook.run("i2.NICs.registered", side, NIC)

     return NIC
end

function unregisterNIC(side)
     local NIC = getAtSide(v)
     if not NIC then return end

     print("[I2] Unregistering NIC: "..v)
     NIC:destroy()

     hook.run("i2.NICs.unregistered", side)
end

function getAny()
     for k, v in pairs(getAll()) do
          return v
     end
end

hook.add("tick", "i2.NICs.peripheral_check", updateNICs)

hook.add("i2.NICs.registered", "i2.MAC.discovery", function(side, NIC)
     NIC:shareMAC()
end)

hook.add("onEvent.modem_message", "i2.NIC.receive", function(side, channel, replyChannel, message, distance)
     if channel ~= I2_CHANNEL or replyChannel ~= I2_CHANNEL then return end

     local frameType = message:sub(1,1)
     local source = mac_address.fromHex(message:sub(2,13))
     local destination = mac_address.fromHex(message:sub(14,25))
     local vlan = simbin.converters.hexToUInt(message:sub(26,28)) or 0
     local body = message:sub(29)
     
     local NIC = existingNICs[side]
     if NIC then
          if frameType == "M" then
               print("[I2] "..(destination == mac_address.zero and "REQ" or "RES").." Opponent's mac on side "..side.." is: "..source)
               NIC:setOpponentsMAC(source)
     
               if destination == mac_address.zero then
                    NIC:shareMAC()
               end

               return
          end
          
          NIC:receive(frameType, source, destination, vlan, body)
     end
end)
