os.loadAPI("/disk/libs/hook")
os.loadAPI("/disk/libs/events")

os.loadAPI("/disk/net/base/i2_switch")

-- Creating NIC for the router
local NICManager = i2_switch.i2_nics
local clientNIC = NICManager.registerNIC("virtual_client", true)

function clientNIC:send(originNIC, frameType, source, destination, frame)
     print("||", "\t", frameType, "\t", source, "\t", destination, "\t", frame)
end

function testFrame(response, destination, body)
     -- i2_switch.onFrame(nil, response and "A" or "R", nil, nil, body)
     clientNIC:receive(response and "A" or "R", clientNIC:getMAC(), destination, body)
end

hook.add("onEvent.key", "i2.test", function(key)
     print("Emitting an event: "..key)
     testFrame(false, "F2:00:00:5D:E9:10", "keypress "..key)
end)

events.startThinking()